<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>Add A Recipe</title>
  </head>
  
  <body>
    <h2>Recipe Form</h2>
    <form method="get" action="new">
      <fieldset>
	Title: <input type="text" name="title" minlength="5" maxlength="50" required /><br /><br />
      </fieldset>
      <fieldset>
	<legend>Instructions</legend>
	<textarea rows="5" cols="30" name="instruction">Enter your instructions here...</textarea>
      </fieldset>
      <input type="submit" value="SUBMIT" />
      <input type="reset" value="CLEAR" />
    </form>
  </body>
</html>
